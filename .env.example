# ===== Base de données Neon PostgreSQL =====
# Récupérez ces valeurs sur https://console.neon.tech
# DATABASE_URL = connexion poolée (pour le runtime serverless)
# DIRECT_URL   = connexion directe (pour les migrations Prisma) — optionnel, fallback sur DATABASE_URL

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/arbitech?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/arbitech?sslmode=require"

# ===== Sécurité Cron Vercel =====
# Secret partagé entre Vercel Cron et la route /api/cron/warm-cache
# Générez une chaîne aléatoire : `openssl rand -hex 32`
CRON_SECRET="change-me-to-a-random-string"

# ===== Notifications Web Push (VAPID) =====
# Générez vos propres clés avec : `npx web-push generate-vapid-keys`
# (le package web-push est déjà installé)
# Collez les valeurs ci-dessous. La clé publique doit aussi être exposée côté client
# via NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY="BJnOPQboxr_F2Lfa60sj9kvQSRZHvfFbdEJ4qeTA7o42iQMQhmSac-4YagoP8fd1dYPlqBsUWtBiPUDQr8m6WKU"
VAPID_PRIVATE_KEY="k0ex-zz72XLLjEbrWn-vxFGT7tYnMDCKXyiqoNwCai0"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BJnOPQboxr_F2Lfa60sj9kvQSRZHvfFbdEJ4qeTA7o42iQMQhmSac-4YagoP8fd1dYPlqBsUWtBiPUDQr8m6WKU"
VAPID_SUBJECT="mailto:contact@arbitech.app"

